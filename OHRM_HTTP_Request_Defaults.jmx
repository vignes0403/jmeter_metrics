            <JSR223Assertion guiclass="TestBeanGUI" testclass="JSR223Assertion" testname="JSR223 Assertion" enabled="true">
              <stringProp name="cacheKey">true</stringProp>
              <stringProp name="filename"></stringProp>
              <stringProp name="parameters"></stringProp>
              <stringProp name="script">// 1. Get the expected result from your CSV
def expected = vars.get(&quot;expected_result&quot;)

// 2. Handle the Redirects (Look at the last sub-result for the actual HTML)
def response = &quot;&quot;
if (prev.getSubResults().length &gt; 0) {
    // If redirects exist, grab the HTML from the final hop
    response = prev.getSubResults()[prev.getSubResults().length - 1].getResponseDataAsString()
} else {
    // If no redirect, grab standard HTML
    response = prev.getResponseDataAsString()
}

// 3. Dynamic Validation Logic
if (expected == &quot;Success&quot;) {
    if (!response.contains(&quot;Dashboard&quot;)) {
        AssertionResult.setFailure(true)
        AssertionResult.setFailureMessage(&quot;Test Failed: Valid credentials were used, but the Dashboard did not load.&quot;)
    }
} 
else if (expected == &quot;Failure&quot;) {
    if (!response.contains(&quot;Invalid credentials&quot;)) {
        AssertionResult.setFailure(true)
        AssertionResult.setFailureMessage(&quot;Test Failed: Invalid credentials were used, but the error message did not appear.&quot;)
    }
}</stringProp>
              <stringProp name="scriptLanguage">groovy</stringProp>
            </JSR223Assertion>
            <hashTree/>
          </hashTree>
